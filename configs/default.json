{
    "project": "motion-style-lora",

    "data": {
        "humanml3d_dir": "/transfer/loradataset/humanml3d",
        "style_data_dir": "/transfer/loradataset/100STYLE",
        "style_converted_dir": "/transfer/loradataset/style_converted",
        "mean_path": "/transfer/loradataset/humanml3d/Mean.npy",
        "std_path": "/transfer/loradataset/humanml3d/Std.npy",
        "njoints": 22,
        "nfeats": 263,
        "max_motion_length": 196,
        "min_motion_length": 40,
        "fps": 20
    },

    "model": {
        "arch": "mdm",
        "latent_dim": 512,
        "ff_size": 1024,
        "num_layers": 8,
        "num_heads": 4,
        "dropout": 0.1,
        "clip_model": "ViT-B-32",
        "clip_pretrained": "openai",
        "clip_dim": 512,
        "cond_mode": "text"
    },

    "lora": {
        "rank": 16,
        "alpha": 16,
        "target_modules": ["to_q", "to_k", "to_v", "to_out"],
        "dropout": 0.05
    },

    "diffusion": {
        "num_timesteps": 1000,
        "beta_schedule": "cosine",
        "snr_gamma": 5.0
    },

    "training": {
        "batch_size": 64,
        "learning_rate": 1e-4,
        "max_train_steps": 2000,
        "gradient_accumulation_steps": 1,
        "lr_scheduler": "cosine",
        "lr_warmup_steps": 100,
        "seed": 42,
        "checkpointing_steps": 500,
        "mixed_precision": "fp16"
    },

    "pretrained_weights": "/transfer/lorapretrain/humanml_trans_enc_512/humanml_trans_enc_512/model000475000.pt",

    "output": {
        "model_dir": "/transfer/outputs/models",
        "generation_dir": "/transfer/outputs/generated",
        "eval_dir": "/transfer/outputs/eval",
        "viz_dir": "/transfer/outputs/viz"
    }
}
